{
  "name": "my-app",
  "main": "client/index.js",
  "version": "1.0.0",
  "scripts": {
    "expo:dev": "EXPO_PACKAGER_PROXY_URL=https://$REPLIT_DEV_DOMAIN REACT_NATIVE_PACKAGER_HOSTNAME=$REPLIT_DEV_DOMAIN EXPO_PUBLIC_DOMAIN=$REPLIT_DEV_DOMAIN:5000 npx expo start --localhost",
    "server:dev": "cross-env NODE_ENV=development tsx server/index.ts",
    "server:dev:nodb": "cross-env NODE_ENV=development DISABLE_DB=1 tsx server/index.ts",
    "expo:start:static:build": "npx expo start --no-dev --minify --localhost",
    "expo:static:build": "node scripts/build.js",
    "build-storybook": "storybook build -c .storybook -o storybook-static",
    "server:build": "esbuild server/index.ts --platform=node --packages=external --bundle --format=esm --outdir=server_dist",
    "server:prod": "cross-env NODE_ENV=production node server_dist/index.js",
    "db:push": "drizzle-kit push",
    "lint": "npx expo lint",
    "lint:fix": "npx expo lint --fix",
    "check:types": "tsc --noEmit",
    "check:format": "prettier --check \"**/*.{js,ts,tsx,css,json}\"",
    "format": "prettier --write \"**/*.{js,ts,tsx,css,json}\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:ui": "vitest --ui",
    "test:check-focused": "node scripts/check-focused-tests.js",
    "test:visual": "chromatic --build-script-name expo:static:build",
    "test:accessibility": "vitest run --reporter=verbose client/**/*.test.{ts,tsx}",
    "test:performance": "vitest bench --config vitest.performance.config.ts --reporter=verbose tests/performance/**/*.test.ts",
    "test:performance:ci": "vitest bench --config vitest.performance.config.ts tests/performance/**/*.test.ts",
    "test:visual:ci": "chromatic --exit-zero-on-changes",
    "test:contracts": "vitest run tests/contracts/**/*.test.ts",
    "test:contracts:consumer": "vitest run tests/contracts/consumer/*.test.ts",
    "test:contracts:provider": "vitest run tests/contracts/provider/*.test.ts --environment node",
    "test:security": "vitest run tests/security/**/*.test.ts",
    "test:compliance": "vitest run tests/compliance/**/*.test.ts",
    "test:metrics": "node scripts/extract-test-metrics.js coverage/test-results.json coverage/test-metrics.json",
    "test:flaky-detect": "node scripts/detect-flaky-tests.js coverage/test-metrics.json coverage/flaky-tests.json",
    "test:trend-analysis": "node scripts/generate-trend-analysis.js coverage coverage/trend-analysis.json",
    "test:update-dashboard": "node scripts/update-metrics-dashboard.js coverage docs/testing/metrics-dashboard.html",
    "security:check": "./scripts/security-check.sh",
    "security:audit": "npm audit --audit-level=moderate",
    "security:sbom": "npx @cyclonedx/cyclonedx-npm --output-file sbom-cyclonedx.json",
    "test:e2e": "detox test --configuration ios.sim.debug",
    "test:e2e:ios": "detox test --configuration ios.sim.debug",
    "test:e2e:ios:release": "detox test --configuration ios.sim.release",
    "test:e2e:android": "detox test --configuration android.emu.debug",
    "test:e2e:android:release": "detox test --configuration android.emu.release",
    "build:e2e:ios": "detox build --configuration ios.sim.debug",
    "build:e2e:ios:release": "detox build --configuration ios.sim.release",
    "build:e2e:android": "detox build --configuration android.emu.debug",
    "build:e2e:android:release": "detox build --configuration android.emu.release"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.600.0",
