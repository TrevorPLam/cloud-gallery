{
  "productName": "Cloud Gallery",
  "version": "1.0.0",
  "identifier": "com.photovault.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist",
    "frontendUrl": "http://localhost:8081"
  },
  "app": {
    "security": {
      "csp": null
    },
    "windows": [
      {
        "title": "Cloud Gallery",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "fileDropEnabled": true
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "fs": {
      "allow": ["watch"],
      "scope": ["$APPDATA/*", "$DOCUMENT/*", "$DOWNLOAD/*", "$PICTURE/*"]
    },
    "dialog": {
      "allow": ["open", "save"]
    },
    "notification": {
      "allow": ["send"]
    },
    "globalShortcut": {
      "allow": ["register", "registerAll", "unregister", "unregisterAll"]
    }
  }
}
