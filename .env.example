# Database connection
# Replace with your actual PostgreSQL connection string
# Format: postgresql://username:password@localhost:5432/database_name
DATABASE_URL=postgresql://gallery:gallery@localhost:5432/gallery

# PostgreSQL Configuration (for Docker Compose)
POSTGRES_USER=gallery
POSTGRES_PASSWORD=gallery
POSTGRES_DB=gallery

# JWT secret (for authentication)
# Generate a secure random string for production
JWT_SECRET=your-super-secret-key-change-in-production

# Node environment
NODE_ENV=production

# Server port
PORT=3000

# Object Storage Configuration (for Docker Compose)
# Storage provider: s3, b2 (Backblaze B2), or minio
STORAGE_PROVIDER=minio
STORAGE_BUCKET=cloud-gallery-photos
STORAGE_REGION=us-east-1

# MinIO Configuration (for Docker Compose)
# Storage credentials (NEVER commit actual values)
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

# Storage endpoints (required for B2 and MinIO)
# For MinIO: http://localhost:9000
# For Backblaze B2: https://s3.us-west-004.backblazeb2.com
# For AWS S3: leave empty (uses regional endpoint)
STORAGE_ENDPOINT=http://localhost:9000

# Optional: File upload settings
MAX_FILE_SIZE=10485760  # 10MB in bytes
ALLOWED_FILE_TYPES=image/jpeg,image/png,image/gif,image/webp

# Optional: For production deployment
# API_BASE_URL=https://your-production-api.com
# UPLOAD_PATH=/uploads
# CORS_ORIGIN=https://your-frontend-domain.com

# Development settings (for local development)
# REPLIT_DEV_DOMAIN=your-domain.repl.co
# REPLIT_DOMAINS=your-domain.repl.co
