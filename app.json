{
  // AI-META-BEGIN
  // AI-META: Expo app configuration with platform-specific settings and permissions
  // OWNERSHIP: config/expo
  // ENTRYPOINTS: used by Expo CLI, Metro bundler, and native app builds
  // DEPENDENCIES: Expo SDK, plugins (splash-screen, image-picker, media-library)
  // DANGER: permissions must match requested features; bundle identifiers must be unique; React compiler is experimental
  // CHANGE-SAFETY: safe to update name/version; icon/splash paths must exist; permissions require app store review; newArchEnabled affects performance
  // TESTS: expo:dev for validation, check platform-specific builds
  // AI-META-END
  "expo": {
    "name": "Photo Vault",
    "slug": "photo-vault",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "photovault",
    "userInterfaceStyle": "automatic",
    // AI-NOTE: newArchEnabled uses React Native's new architecture for better performance; may have compatibility issues with older libraries
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.photovault.app",
      // AI-NOTE: infoPlist strings shown to users when requesting permissions; be clear and non-intrusive
      "infoPlist": {
        "NSPhotoLibraryUsageDescription": "Photo Vault needs access to your photos to help you organize and store your memories.",
        "NSCameraUsageDescription": "Photo Vault needs camera access to take photos directly in the app.",
        "NSPhotoLibraryAddUsageDescription": "Photo Vault needs permission to save shared photos to your photo library."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#2D3748",
        "foregroundImage": "./assets/images/icon.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.photovault.app",
      // AI-NOTE: READ/WRITE_EXTERNAL_STORAGE needed for photo access on older Android; newer versions use scoped storage
      "permissions": [
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.CAMERA"
      ]
    },
    "web": {
      "output": "single",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#2D3748",
          "dark": {
            "backgroundColor": "#1A202C"
          }
        }
      ],
      "expo-web-browser",
      [
        "expo-image-picker",
        {
          "photosPermission": "Photo Vault needs access to your photos to help you organize and store your memories.",
          "cameraPermission": "Photo Vault needs camera access to take photos directly in the app."
        }
      ],
      [
        "expo-media-library",
        {
          "photosPermission": "Photo Vault needs access to your photo library to save and organize photos.",
          "savePhotosPermission": "Photo Vault needs permission to save photos to your library.",
          "isAccessMediaLocationEnabled": true
        }
      ],
      [
        "react-native-share",
        {
          "ios": [
            "fb",
            "instagram",
            "twitter",
            "tiktoksharesdk"
          ],
          "android": [
            "com.facebook.katana",
            "com.instagram.android",
            "com.twitter.android",
            "com.zhiliaoapp.musically"
          ],
          "enableBase64ShareAndroid": true
        }
      ]
    ],
    // AI-NOTE: React compiler experimental feature enables automatic memoization; may cause unexpected re-rendering behavior
    "experiments": {
      "reactCompiler": true
    }
  }
}
